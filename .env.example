# ── Copy this file to .env and fill in real values. NEVER commit .env. ──

# Required: OpenAI key for GPT-4o (command parsing) + Whisper (transcription)
OPENAI_API_KEY=sk-...

# Optional: model overrides (defaults are sensible)
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# Production only: Cloudinary for video storage (free tier ~25GB)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# Optional: LangSmith tracing for the LangGraph agent
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-video-editor

# Backend config
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=500
FRONTEND_ORIGIN=http://localhost:5173
