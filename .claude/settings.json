{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(python:*)",
      "Bash(python -m:*)",
      "Bash(pytest:*)",
      "Bash(flake8:*)",
      "Bash(uvicorn:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ffmpeg:*)",
      "Bash(ffprobe:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/lint_python.py"
          }
        ]
      }
    ]
  },
  "_note": "PostToolUse pytest hook is added on Day 11. The PreToolUse hook lints Python content before writes (see .claude/hooks/lint_python.py)."
}
